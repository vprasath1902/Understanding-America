{
  "_comment": "Canonical visual design tokens for Understanding America. Mirrors the CSS :root variables in css/styles.css. The visual toolkit (W2) and all authored SVGs consume these so the ~190+ assets stay consistent.",
  "palette": {
    "navy": "#0b3c6d",
    "red": "#b22234",
    "gold": "#c9a227",
    "green": "#2e8b57",
    "purple": "#6a4c93",
    "ink": "#1f2937",
    "muted": "#667085",
    "paper": "#f8f8f6",
    "card": "#ffffff",
    "line": "#d8dee8"
  },
  "typography": {
    "family": "Arial, Helvetica, sans-serif",
    "heading": { "weight": 800, "fill": "navy" },
    "subtle": { "fill": "muted" },
    "sizes": { "title": 30, "heading": 22, "label": 15 }
  },
  "stroke": {
    "connector": { "color": "navy", "width": 4, "linecap": "round" },
    "rule": { "color": "gold", "width": 6 },
    "box": { "color": "line", "width": 2 }
  },
  "shape": { "boxRadius": 18, "canvasRadius": 24 },
  "marker": { "dotFill": "red", "dotRadius": 12 },
  "background": "paper"
}
